# ============================================================
# .env — Environment Variables (NEVER commit this file to Git!)
# ============================================================
# Copy this file as ".env" and fill in your real values.
# Each value below comes from a different dashboard:

# ── SUPABASE ─────────────────────────────────────────────────
# From: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── GOOGLE GEMINI ─────────────────────────────────────────────
# From: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── SERVER ───────────────────────────────────────────────────
PORT=3000

# ── FRONTEND URL (for CORS) ───────────────────────────────────
# In development: http://localhost:3000
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── GMAIL (for contact form emails) ─────────────────────────
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
# This is NOT your Gmail password, it's a special app-specific password
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASSWORD=your-app-password
CONTACT_EMAIL=your-recipient-email@gmail.com
